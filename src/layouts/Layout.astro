---
interface Props {
    title: string;
}

const { title } = Astro.props;
// Lấy đường dẫn hiện tại để xác định tab nào đang active
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname === '/' ? '/' : pathname.replace(/\/$/, '');

// Danh sách các tab và đường dẫn (ĐÃ CHUYỂN TIẾNG VIỆT, ĐỔI THÀNH THÔNG BÁO VÀ CHƯƠNG TRÌNH, BỎ HISTORY)
const navItems = [
  { name: 'Trang chủ', href: '/' },
  { name: 'Ban tổ chức', href: '/committee' },
  { name: 'Diễn giả chính', href: '/speakers' },
  { name: 'Thông báo', href: '/call-for-papers' }, 
  { name: 'Chương trình', href: '/for-attendees' },
  { name: 'Liên hệ', href: '/contact' },
];
---

<!doctype html>
<html lang="vi" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="AI4Econ&Biz 2026 - Hội thảo Khoa học Quốc gia" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.png" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <title>{title}</title>
    </head>
    <body class="bg-white font-['Inter',_sans-serif] text-slate-900">
        
        <header class="bg-white border-b border-slate-100 sticky top-0 z-50 shadow-sm">
            <div class="max-w-[1440px] mx-auto px-4 lg:px-8">
                
                <div class="flex items-center justify-between h-24">
                    
                    <div class="flex items-center gap-6 shrink-0">
                        <div class="flex items-center gap-3 pr-6 border-r border-slate-200">
                            <img src="/logos/ftu-logo.png" alt="FTU Logo" class="h-12 w-auto object-contain" />
                            <img src="/logos/fisu-logo.png" alt="FISU logo" class="h-8 w-auto opacity-80 hover:opacity-100 transition-opacity" />
                            <img src="/logos/hthvn-logo.jpg" alt="HTHVN logo" class="h-8 w-auto opacity-80 hover:opacity-100 transition-opacity" />
                        </div>
                        
                        <div class="flex flex-col">
                            <span class="text-blue-950 font-black text-xl tracking-tighter leading-none">AI4Econ&Biz</span>
                            <span class="text-orange-600 font-bold text-lg leading-none">2026</span>
                        </div>
                    </div>

                    <nav class="hidden xl:flex items-center gap-x-2 2xl:gap-x-4">
                    {navItems.map((item) => {
                        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
                        
                        // Chèn 3 nút tính năng hành động nổi bật vào trước mục Liên hệ
                        if (item.name === 'Liên hệ') {
                            return (
                                <>
                                <a 
                                    href="/submit-paper" 
                                    class="whitespace-nowrap bg-blue-950 hover:bg-blue-900 text-white px-4 py-2.5 rounded-full text-xs font-bold shadow-sm transition-all hover:scale-105 active:scale-95"
                                >
                                    GỬI BÀI
                                </a>

                                <a 
                                    href="/ai-challenge" 
                                    class="whitespace-nowrap bg-orange-600 hover:bg-orange-700 text-white px-4 py-2.5 rounded-full text-xs font-bold shadow-sm transition-all hover:scale-105 active:scale-95"
                                >
                                    AI CHALLENGE
                                </a>

                                <a 
                                    href="/industrial-show" 
                                    class="whitespace-nowrap bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 rounded-full text-xs font-bold shadow-sm transition-all hover:scale-105 active:scale-95"
                                >
                                    INDUSTRIAL SHOW
                                </a>
                                
                                <a 
                                    href={item.href} 
                                    class={`whitespace-nowrap relative px-2.5 py-2 text-xs 2xl:text-sm font-semibold transition-all duration-300 hover:text-blue-700 ${isActive ? 'text-blue-900' : 'text-slate-500'}`}
                                >
                                    {item.name}
                                    {isActive && <span class="absolute bottom-0 left-2.5 right-2.5 h-0.5 bg-orange-500 rounded-full"></span>}
                                </a>
                                </>
                            );
                        }

                        return (
                            <a 
                                href={item.href} 
                                class={`whitespace-nowrap relative px-2.5 py-2 text-xs 2xl:text-sm font-semibold transition-all duration-300 hover:text-blue-700 ${isActive ? 'text-blue-900' : 'text-slate-500'}`}
                            >
                                {item.name}
                                {isActive && <span class="absolute bottom-0 left-2.5 right-2.5 h-0.5 bg-orange-500 rounded-full"></span>}
                            </a>
                        );
                    })}
                    </nav>

                    <button id="menu-btn" class="xl:hidden text-slate-900 p-2 focus:outline-none select-none">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                        </svg>
                    </button>
                </div>
            </div>
        </header>

        <div id="mobile-menu" class="hidden xl:hidden fixed top-24 left-0 w-full bg-white border-b border-slate-200 shadow-lg z-40 flex flex-col p-4 space-y-2 max-h-[calc(100vh-96px)] overflow-y-auto">
            
            <a href="/submit-paper" class="bg-blue-950 text-white text-center py-2.5 rounded-xl text-xs font-bold shadow-sm">
                📝 GỬI BÀI
            </a>
            <a href="/ai-challenge" class="bg-orange-600 text-white text-center py-2.5 rounded-xl text-xs font-bold shadow-sm">
                AI CHALLENGE
            </a>
            <a href="/industrial-show" class="bg-indigo-600 text-white text-center py-2.5 rounded-xl text-xs font-bold shadow-sm">
                INDUSTRIAL SHOW
            </a>
            
            <hr class="border-slate-100 my-2" />

            {navItems.map((item) => {
                const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
                return (
                    <a href={item.href} class={`py-2 px-3 rounded-lg text-sm font-bold ${isActive ? 'bg-slate-100 text-blue-950' : 'text-slate-600'}`}>
                        {item.name}
                    </a>
                );
            })}
        </div>

        <slot />

        <footer class="bg-blue-950 text-white py-12 px-6">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 border-t border-blue-900 pt-12">
                <div>
                    <h3 class="text-xl font-bold mb-4">AI4Econ&Biz 2026</h3>
                    <p class="text-blue-200 text-sm max-w-md">Kết nối Trí tuệ Nhân tạo với Sự phát triển Kinh tế và Kinh doanh Toàn cầu. Tổ chức bởi Trường Đại học Ngoại thương và các Đối tác.</p>
                </div>
                <div class="text-right flex items-end justify-end p-0 md:pt-6">
                    <p class="text-sm text-blue-300">© 2026 Trường Đại học Ngoại thương. Bản quyền đã được bảo lưu.</p>
                </div>
            </div>
        </footer>

        <script is:inline>
          document.addEventListener('DOMContentLoaded', () => {
            const menuBtn = document.getElementById('menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');

            if (menuBtn && mobileMenu) {
              menuBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                mobileMenu.classList.toggle('hidden');
              });

              document.addEventListener('click', (e) => {
                if (!mobileMenu.contains(e.target) && !menuBtn.contains(e.target)) {
                  mobileMenu.classList.add('hidden');
                }
              });
            }
          });
        </script>

    </body>
</html>

<style is:global>
    .nav-underline-anim {
        @apply transition-all duration-300;
    }
</style>