---

<Layout title="Ban tổ chức - AI4Econ&Biz 2026">
  <main class="bg-slate-50 font-sans text-slate-900 cursor-default py-12 min-h-screen">
    
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      
      <div class="border-b-2 border-blue-950 pb-4 mb-8 flex items-center justify-between">
        <h1 class="text-xl md:text-2xl font-black text-blue-950 uppercase tracking-tight">
          👥 BAN TỔ CHỨC HỘI THẢO
        </h1>
        <span class="bg-orange-100 text-orange-800 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-sm hidden sm:inline-block">
          Hội đồng khoa học
        </span>
      </div>

      <div class="space-y-4">
        {committees.map((group) => (
          <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col md:flex-row md:items-start gap-4 hover:border-blue-100 transition-all">
            
            <div class="md:w-1/3 shrink-0 border-b md:border-b-0 md:border-r border-slate-100 pb-2 md:pb-0 md:pr-4">
              <div class="flex items-center gap-2">
                <span class="h-1.5 w-1.5 bg-orange-500 rounded-full shrink-0"></span>
                <h2 class="text-xs font-bold text-orange-600 uppercase tracking-wide">
                  {group.category}
                </h2>
              </div>
            </div>

            <div class="md:w-2/3 flex flex-wrap gap-2">
              {group.members.map((member) => (
                <div class="bg-slate-50/80 border border-slate-200/60 rounded-xl px-3 py-2 text-xs flex flex-col sm:flex-row sm:items-center gap-x-2 gap-y-0.5 hover:border-blue-400 hover:bg-blue-50/10 transition-all">
                  <span class="font-bold text-slate-800 whitespace-nowrap">{member.name}</span>
                  <span class="text-slate-300 hidden sm:inline">|</span>
                  <span class="text-slate-500 font-medium italic text-[11px]">{member.institution}</span>
                </div>
              ))}
            </div>

          </div>
        ))}
      </div>

    </div>
    
  </main>
</Layout>