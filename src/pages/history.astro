---
import Layout from '../layouts/Layout.astro';
---

<Layout title="History - AI4Econ&Biz 2026">
  <main class="bg-white font-sans text-slate-900 cursor-default py-10 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      
      <!-- TIÊU ĐỀ CHÍNH TRÊN NỀN TRẮNG -->
      <div class="border-b-2 border-orange-500 pb-3 mb-6">
        <h1 class="text-2xl font-black text-blue-950 uppercase tracking-tight">
          Conference History
        </h1>
      </div>

      <!-- ĐỂ TRỐNG NỘI DUNG ĐỂ EDIT SAU -->
      <div class="py-20 text-center text-slate-300 text-sm italic select-none">
        <!-- Nội dung lịch sử hội thảo sẽ được cập nhật tại đây -->
      </div>

    </div>
  </main>
</Layout>