---
import Layout from '../layouts/Layout.astro';

// HỆ THỐNG DỮ LIỆU DIỄN GIẢ CHÍNH (Sinh viên chỉnh sửa thông tin tại đây)
const keynoteSpeakers = [
  {
    name: "Prof. Dr. [Keynote Speaker One]",
    institution: "International University / Renowned Research Lab",
    topic: "Strategic Integration of AI in Global Economic Models and Future Business Paradigms",
    image: "/images/speakers/speaker1.jpg" // Đường dẫn ảnh của diễn giả
  },
  {
    name: "Dr. [Keynote Speaker Two]",
    institution: "Leading Tech Corporation / AI Research Institute",
    topic: "Advanced Machine Learning Frameworks and Technology Transfer for Corporate Operations",
    image: "/images/speakers/speaker2.jpg"
  },
  {
    name: "Assoc. Prof. Dr. [Keynote Speaker Three]",
    institution: "Foreign Trade University (FTU) / FISU Vietnam",
    topic: "Fostering Sustainable Economic Growth through Responsible AI Applications",
    image: "/images/speakers/speaker3.jpg"
  }
];
---

<Layout title="Keynote Speakers - AI4Econ&Biz 2026">
  <main class="bg-slate-50 font-sans text-slate-900 cursor-default py-10 min-h-screen">
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      
      <div class="border-b-2 border-orange-500 pb-4 mb-8">
        <h1 class="text-2xl md:text-3xl font-black text-blue-950 uppercase tracking-tight">
          Keynote Speakers
        </h1>
      </div>

      <div class="space-y-4">
        {keynoteSpeakers.map((speaker, index) => (
          <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex flex-col sm:flex-row items-center sm:items-start gap-5 hover:border-blue-400 transition-all group">
            
            <div class="w-20 h-20 rounded-full overflow-hidden bg-slate-100 border border-slate-200 shrink-0 shadow-inner">
              <img 
                src={speaker.image} 
                alt={speaker.name} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                onerror="this.src='https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?q=80&w=200';" 
              />
            </div>

            <div class="flex-1 text-center sm:text-left space-y-1">
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3">
                <h2 class="text-base font-bold text-slate-800 group-hover:text-blue-950 transition-colors">
                  {speaker.name}
                </h2>
                <span class="text-slate-300 hidden sm:inline">|</span>
                <p class="text-xs font-semibold text-slate-500 italic">
                  {speaker.institution}
                </p>
              </div>
              
              <div class="pt-1.5 flex items-start gap-2 justify-center sm:justify-start">
                <span class="text-[10px] font-bold text-orange-600 bg-orange-50 px-2 py-0.5 rounded uppercase tracking-wider shrink-0 mt-0.5">
                  Presentation Topic
                </span>
                <p class="text-xs font-medium text-slate-600 leading-relaxed text-justify">
                  "{speaker.topic}"
                </p>
              </div>
            </div>

          </div>
        ))}
      </div>

    </div>
    
  </main>
</Layout>