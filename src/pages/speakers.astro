---
import Layout from '../layouts/Layout.astro';

// HỆ THỐNG DỮ LIỆU DIỄN GIẢ CHÍNH - ĐÃ VIỆT HÓA CHUẨN KHOA HỌC
const keynoteSpeakers = [
  {
    name: "GS. TS. [Diễn giả chính 1]",
    institution: "Đại học Quốc tế / Phòng thí nghiệm Nghiên cứu Trọng điểm",
    topic: "Tích hợp chiến lược AI trong các mô hình kinh tế toàn cầu và xu hướng quản trị kinh doanh tương lai",
    image: "/images/speakers/speaker1.jpg" // Đường dẫn ảnh của diễn giả
  },
  {
    name: "TS. [Diễn giả chính 2]",
    institution: "Tập đoàn Công nghệ Hàng đầu / Viện Nghiên cứu AI",
    topic: "Hệ thống Học máy Nâng cao và giải pháp chuyển giao công nghệ cho vận hành doanh nghiệp",
    image: "/images/speakers/speaker2.jpg"
  },
  {
    name: "PGS. TS. [Diễn giả chính 3]",
    institution: "Trường Đại học Ngoại thương (FTU) / FISU Việt Nam",
    topic: "Thúc đẩy tăng trưởng kinh tế bền vững thông qua các ứng dụng AI có trách nhiệm",
    image: "/images/speakers/speaker3.jpg"
  }
];
---

<Layout title="Diễn giả chính - AI4Econ&Biz 2026">
  <main class="bg-slate-50 font-sans text-slate-900 cursor-default py-12 min-h-screen">
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      
      <div class="border-b-2 border-blue-950 pb-4 mb-8 flex items-center justify-between">
        <h1 class="text-xl md:text-2xl font-black text-blue-950 uppercase tracking-tight">
          🎤 DIỄN GIẢ CHÍNH (KEYNOTE SPEAKERS)
        </h1>
        <span class="bg-orange-100 text-orange-800 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-sm hidden sm:inline-block">
          Chuyên gia đầu ngành
        </span>
      </div>

      <div class="space-y-4">
        {keynoteSpeakers.map((speaker, index) => (
          <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col sm:flex-row items-center sm:items-start gap-6 hover:border-blue-400 hover:shadow-md transition-all duration-300 group">
            
            <div class="w-24 h-24 rounded-full overflow-hidden bg-slate-100 border-2 border-slate-200 shrink-0 shadow-sm group-hover:border-blue-500 transition-colors">
              <img 
                src={speaker.image} 
                alt={speaker.name} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                onerror="this.src='https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?q=80&w=200';" 
              />
            </div>

            <div class="flex-1 text-center sm:text-left space-y-2">
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3">
                <h2 class="text-base font-extrabold text-slate-800 group-hover:text-blue-950 transition-colors">
                  {speaker.name}
                </h2>
                <span class="text-slate-300 hidden sm:inline">|</span>
                <p class="text-xs font-bold text-blue-600 italic">
                  {speaker.institution}
                </p>
              </div>
              
              <div class="pt-2 flex flex-col sm:flex-row items-center sm:items-start gap-2 justify-center sm:justify-start">
                <span class="whitespace-nowrap text-[10px] font-bold text-orange-600 bg-orange-50 px-2.5 py-1 rounded uppercase tracking-wider shrink-0 mt-0.5 border border-orange-100">
                  Chủ đề bài luận
                </span>
                <p class="text-xs font-semibold text-slate-600 leading-relaxed text-justify md:text-left">
                  "{speaker.topic}"
                </p>
              </div>
            </div>

          </div>
        ))}
      </div>

    </div>
    
  </main>
</Layout>