---
import Layout from '../layouts/Layout.astro';

// CÁC HẠNG MỤC HỢP TÁC DÀNH CHO DOANH NGHIỆP
const showHighlights = [
  {
    title: "Cutting-Edge Exhibition",
    description: "A premium space for tech enterprises to showcase advanced AI models, automation solutions, and smart business applications directly to key stakeholders.",
    badge: "Showcase"
  },
  {
    title: "B2B Strategic Networking",
    description: "An exclusive cross-sector networking hub designed to bridge corporate leaders, research institutes, policymakers, and venture capitalists.",
    badge: "Connect"
  },
  {
    title: "Technology Transfer",
    description: "A practical platform driving the commercialization of scientific research, deploying robust AI frameworks straight into corporate operations.",
    badge: "Deploy"
  }
];
---

<Layout title="Industrial Show - AI4Econ&Biz 2026">
  <main class="bg-slate-50 font-sans text-slate-900 cursor-default py-10 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      
      <!-- TIÊU ĐỀ CHÍNH - PHONG CÁCH B2B TỐI GIẢN SANG TRỌNG -->
      <div class="border-b-2 border-slate-900 pb-3 mb-8 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
        <h1 class="text-2xl font-black text-blue-950 uppercase tracking-tight">
          💼 Industrial Show 2026
        </h1>
        <p class="text-xs font-bold text-orange-600 uppercase tracking-widest">
          Corporate Partnerships & Tech Deployment
        </p>
      </div>

      <!-- 1. TỔNG QUAN GIÁ TRỊ (VALUE PROPOSITION) -->
      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm mb-6 grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
        <div class="md:col-span-2 space-y-2">
          <span class="bg-slate-100 text-slate-800 font-bold text-[9px] uppercase tracking-widest px-2 py-0.5 rounded border border-slate-200">
            Co-organized with FISU Vietnam
          </span>
          <p class="text-xs md:text-sm text-slate-600 leading-relaxed text-justify">
            Running parallel to the scientific conference, the <strong>Industrial Show</strong> within the <strong>AI4Econ&Biz 2026</strong> event series stands as a high-level networking space. This initiative is tailor-made for corporations, tech startups, and enterprises to bridge the gap between academic excellence and real-world industrial impact.
          </p>
        </div>
        
        <!-- Khối CTA nhanh cho Doanh nghiệp -->
        <div class="bg-slate-900 text-white p-4 rounded-xl text-center space-y-2 border border-slate-850 shadow">
          <p class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider">Booth Registration</p>
          <p class="text-xs font-medium text-slate-300">Limited slots available for corporate partners.</p>
          <a href="mailto:conference@ftu.edu.vn" class="inline-block bg-orange-500 hover:bg-orange-600 text-white text-[11px] font-bold uppercase tracking-wider px-4 py-2 rounded shadow-sm w-full transition-all">
            Contact for Booths
          </a>
        </div>
      </div>

      <!-- 2. TRỤ CỘT HOẠT ĐỘNG (PILLARS) - THIẾT KẾ PHẲNG, HIỆN ĐẠI -->
      <div class="space-y-4">
        <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Core Opportunities for Partners</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {showHighlights.map((item) => (
            <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm hover:border-slate-900 hover:shadow transition-all flex flex-col justify-between group">
              <div class="space-y-2">
                <span class="inline-block bg-orange-50 text-orange-700 border border-orange-100 font-bold text-[9px] uppercase tracking-wider px-2 py-0.5 rounded">
                  {item.badge}
                </span>
                <h3 class="text-sm font-bold text-blue-950 tracking-tight group-hover:text-orange-600 transition-colors">
                  {item.title}
                </h3>
                <p class="text-xs text-slate-500 leading-relaxed text-justify font-light">
                  {item.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 3. ĐƠN VỊ ĐỒNG HÀNH (NETWORKING PARTNERS) -->
      <div class="mt-6 bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div class="space-y-0.5">
            <h3 class="text-xs font-bold text-blue-950 uppercase tracking-wider">Strategic Tech Network</h3>
            <p class="text-[11px] text-slate-500 italic">Connecting academia with top-tier technology institutions and business communities.</p>
          </div>
          <div class="flex items-center gap-4 border-t sm:border-t-0 sm:border-l border-slate-100 pt-3 sm:pt-0 sm:pl-4 shrink-0">
            <span class="text-[11px] font-semibold text-slate-400 uppercase tracking-widest">In Partnership with</span>
            <div class="font-black text-sm text-slate-300 tracking-tighter uppercase select-none">
              FISU <span class="text-orange-500">VIETNAM</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>