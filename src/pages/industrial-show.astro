---
import Layout from '../layouts/Layout.astro';

// CÁC HẠNG MỤC HỢP TÁC DÀNH CHO DOANH NGHIỆP - ĐÃ VIỆT HÓA CHUẨN THƯƠNG MẠI
const showHighlights = [
  {
    title: "Triển lãm Công nghệ Đột phá",
    description: "Không gian cao cấp dành cho các doanh nghiệp công nghệ trình diễn các mô hình AI tiên tiến, giải pháp tự động hóa và ứng dụng kinh doanh thông minh trực tiếp tới các đối tác chiến lược.",
    badge: "Trưng bày"
  },
  {
    title: "Kết nối Chiến lược B2B",
    description: "Mạng lưới giao thương đặc quyền được thiết kế nhằm bắc cầu hợp tác giữa các nhà lãnh đạo doanh nghiệp, viện nghiên cứu, nhà hoạch định chính sách và các quỹ đầu tư mạo hiểm.",
    badge: "Kết nối"
  },
  {
    title: "Chuyển giao Công nghệ",
    description: "Nền tảng thực tiễn thúc đẩy thương mại hóa các kết quả nghiên cứu khoa học, triển khai trực tiếp các hệ thống AI mạnh mẽ vào quy trình vận hành thực tế của doanh nghiệp.",
    badge: "Triển khai"
  }
];
---

<Layout title="Industrial Show - AI4Econ&Biz 2026">
  <main class="bg-slate-50 font-sans text-slate-900 cursor-default py-10 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      
      <div class="border-b-2 border-slate-900 pb-3 mb-8 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
        <h1 class="text-2xl font-black text-blue-950 uppercase tracking-tight">
          💼 Industrial Show 2026
        </h1>
        <p class="text-xs font-bold text-orange-600 uppercase tracking-widest">
          Hợp tác Doanh nghiệp & Triển khai Công nghệ
        </p>
      </div>

      <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm mb-6 grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
        <div class="md:col-span-2 space-y-2">
          <span class="bg-slate-100 text-slate-800 font-bold text-[9px] uppercase tracking-widest px-2 py-0.5 rounded border border-slate-200">
            Phối hợp tổ chức cùng FISU Việt Nam
          </span>
          <p class="text-xs md:text-sm text-slate-600 leading-relaxed text-justify">
            Diễn ra song song với hội thảo khoa học, không gian triển lãm <strong>Industrial Show</strong> thuộc chuỗi sự kiện <strong>AI4Econ&Biz 2026</strong> là diễn đàn giao thương cấp cao. Đây là sáng kiến được thiết kế riêng cho các tập đoàn, startup công nghệ và doanh nghiệp nhằm thu hẹp khoảng cách giữa nghiên cứu học thuật xuất sắc với các ứng dụng thực tiễn trong nền công nghiệp.
          </p>
        </div>
        
        <div class="bg-slate-900 text-white p-4 rounded-xl text-center space-y-2 border border-slate-800 shadow">
          <p class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider">Đăng ký gian hàng</p>
          <p class="text-xs font-medium text-slate-300">Số lượng vị trí trưng bày có hạn dành cho các đối tác doanh nghiệp.</p>
          <a href="mailto:conference@ftu.edu.vn" class="inline-block bg-orange-500 hover:bg-orange-600 text-white text-[11px] font-bold uppercase tracking-wider px-4 py-2 rounded shadow-sm w-full transition-all text-center">
            Liên hệ đặt gian hàng
          </a>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Cơ hội cốt lõi dành cho đối tác</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {showHighlights.map((item) => (
            <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm hover:border-slate-900 hover:shadow transition-all flex flex-col justify-between group">
              <div class="space-y-2">
                <span class="inline-block bg-orange-50 text-orange-700 border border-orange-100 font-bold text-[9px] uppercase tracking-wider px-2 py-0.5 rounded">
                  {item.badge}
                </span>
                <h3 class="text-sm font-bold text-blue-950 tracking-tight group-hover:text-orange-600 transition-colors">
                  {item.title}
                </h3>
                <p class="text-xs text-slate-500 leading-relaxed text-justify font-light">
                  {item.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-6 bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div class="space-y-0.5">
            <h3 class="text-xs font-bold text-blue-950 uppercase tracking-wider">Mạng lưới công nghệ chiến lược</h3>
            <p class="text-[11px] text-slate-500 italic">Kết nối tri thức học thuật với các tổ chức công nghệ hàng đầu và cộng đồng doanh nghiệp vĩ mô.</p>
          </div>
          <div class="flex items-center gap-4 border-t sm:border-t-0 sm:border-l border-slate-100 pt-3 sm:pt-0 sm:pl-4 shrink-0">
            <span class="text-[11px] font-semibold text-slate-400 uppercase tracking-widest">Đồng hành cùng</span>
            <div class="font-black text-sm text-slate-300 tracking-tighter uppercase select-none">
              FISU <span class="text-orange-500">VIỆT NAM</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>