---
import Layout from '../layouts/Layout.astro';

// CẤU HÌNH THÔNG TIN ĐĂNG KÝ (Sinh viên chỉnh sửa tại đây)
const registrationTypes = [
  { role: "Authors (With Accepted Papers)", fee: "Free of Charge", status: "Open" },
  { role: "Academic Observers / Presenters", fee: "Free of Charge", status: "Open" },
  { role: "Students / AI Challenge Participants", fee: "Free of Charge", status: "Open" },
  { role: "Corporate Representatives / Industry Guests", fee: "Free of Charge", status: "By Invitation" }
];
---

<Layout title="Attendees - AI4Econ&Biz 2026">
  <main class="bg-slate-50 font-sans text-slate-900 cursor-default py-10 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      
      <div class="border-b-2 border-orange-500 pb-3 mb-6">
        <h1 class="text-2xl font-black text-blue-950 uppercase tracking-tight">
          Registration Information
        </h1>
      </div>

      <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm mb-6 text-sm text-slate-600 text-justify leading-relaxed">
        <p>
          We welcome researchers, practitioners, students, and tech enthusiasts to join the <strong>AI4Econ&Biz 2026</strong> event series. Registration is mandatory for all attendees to secure access to the Scientific Conference sessions, AI Challenge finals, and the Industrial Show.
        </p>
      </div>

      

    </div>
  </main>
</Layout>