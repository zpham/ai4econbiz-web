---
import Layout from '../layouts/Layout.astro';

// CẤU HÌNH THÔNG TIN ĐĂNG KÝ - ĐÃ VIỆT HÓA CHUẨN XÁC
const registrationTypes = [
  { role: "Tác giả (Có bài báo được chấp nhận)", fee: "Miễn phí", status: "Đang mở" },
  { role: "Học giả / Đại biểu tham luận", fee: "Miễn phí", status: "Đang mở" },
  { role: "Học sinh - Sinh viên / Thí sinh cuộc thi AI Challenge", fee: "Miễn phí", status: "Đang mở" },
  { role: "Đại diện Doanh nghiệp / Khách mời khối Công nghiệp", fee: "Miễn phí", status: "Theo thư mời" }
];
---

<Layout title="Chương trình - AI4Econ&Biz 2026">
  <main class="bg-slate-50 font-sans text-slate-900 cursor-default py-12 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      
      <div class="border-b-2 border-blue-950 pb-3 mb-6 flex items-center justify-between">
        <h1 class="text-xl md:text-2xl font-black text-blue-950 uppercase tracking-tight">
          📋 THÔNG TIN ĐĂNG KÝ THAM DỰ
        </h1>
        <span class="bg-orange-100 text-orange-800 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-sm hidden sm:inline-block">
          Dành cho đại biểu
        </span>
      </div>

      <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm mb-6 text-sm text-slate-600 text-justify leading-relaxed">
        <p>
          Ban Tổ chức nồng nhiệt chào đón các nhà nghiên cứu, chuyên gia, học sinh - sinh viên và những người đam mê công nghệ tham gia chuỗi sự kiện <strong>AI4Econ&Biz 2026</strong>. Việc đăng ký tham dự là bắt buộc đối với tất cả các đại biểu để đảm bảo quyền truy cập vào các phiên của Hội thảo Khoa học, vòng chung kết cuộc thi AI Challenge và khu vực Triển lãm Industrial Show.
        </p>
      </div>

      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-4 bg-slate-50 border-b border-slate-200 flex items-center justify-between">
          <h2 class="text-xs font-bold text-blue-950 uppercase tracking-wider">Phân loại đối tượng & Lệ phí</h2>
        </div>
        
        <div class="divide-y divide-slate-100">
          {registrationTypes.map((type) => (
            <div class="p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3 hover:bg-slate-50/50 transition-colors">
              <div class="space-y-1">
                <p class="text-sm font-bold text-slate-800">{type.role}</p>
                <div class="flex items-center gap-2">
                  <span class="text-[10px] uppercase font-bold text-slate-400">Lệ phí:</span>
                  <span class="text-xs font-extrabold text-emerald-600">{type.fee}</span>
                </div>
              </div>
              
              <div class="shrink-0">
                <span class={`inline-block text-center text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider min-w-[110px] ${
                  type.status === 'Đang mở' 
                    ? 'bg-green-100 text-green-700 border border-green-200' 
                    : 'bg-blue-50 text-blue-700 border border-blue-100'
                }`}>
                  {type.status}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-8 bg-blue-950 text-white p-5 rounded-2xl border border-blue-900 shadow-md flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="space-y-0.5 text-center sm:text-left">
          <h3 class="text-sm font-bold uppercase tracking-tight">Cổng đăng ký trực tuyến</h3>
          <p class="text-xs text-blue-200">Vui lòng hoàn thành form đăng ký để Ban Tổ chức chuẩn bị đón tiếp chu đáo nhất.</p>
        </div>
        <a 
          href="#form-dang-ky" 
          class="whitespace-nowrap bg-orange-500 hover:bg-orange-600 text-white px-5 py-2.5 rounded-xl text-xs font-bold shadow-sm transition-all hover:scale-105 active:scale-95"
        >
          ĐĂNG KÝ NGAY
        </a>
      </div>

    </div>
  </main>
</Layout>