---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us - AI4Econ&Biz 2026">
  <main class="bg-slate-50 font-sans text-slate-900 cursor-default py-10 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      
      <!-- TIÊU ĐỀ CHÍNH -->
      <div class="border-b-2 border-orange-500 pb-3 mb-6">
        <h1 class="text-2xl font-black text-blue-950 uppercase tracking-tight">
          Contact Us
        </h1>
      </div>

      <!-- ĐOẠN DẪN DẮT -->
      <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm mb-6 text-xs md:text-sm text-slate-600 text-justify leading-relaxed">
        <p>
          For any inquiries regarding paper submissions, registration, corporate sponsorship, or exhibition booths, please contact the AI4Econ&Biz 2026 Organizing Committee through the official channels below.
        </p>
      </div>

      <!-- LƯỚI ĐẦU MỐI LIÊN HỆ GỌN GÀNG (2 CỘT SONG SONG) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        
        <!-- ĐẦU MỐI 1: THƯỜNG TRỰC BAN TỔ CHỨC (FTU) -->
        <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between hover:border-blue-400 transition-colors">
          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <span class="text-lg">🏫</span>
              <h2 class="text-xs font-bold text-blue-950 uppercase tracking-wider">Conference Secretariat</h2>
            </div>
            <div class="space-y-1 text-xs text-slate-600">
              <p class="font-bold text-slate-800">Foreign Trade University (FTU)</p>
              <p>📍 91 Chua Lang Street, Lang Thuong, Dong Da, Hanoi, Vietnam</p>
              <p>✉️ Email: <a href="mailto:conference@ftu.edu.vn" class="text-orange-600 hover:underline font-mono">conference@ftu.edu.vn</a></p>
            </div>
          </div>
        </div>

        <!-- ĐẦU MỐI 2: ĐỒNG TỔ CHỨC & HỖ TRỢ CHUYÊN MÔN (FISU) -->
        <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between hover:border-indigo-400 transition-colors">
          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <span class="text-lg">🤖</span>
              <h2 class="text-xs font-bold text-blue-950 uppercase tracking-wider">Technical & Network Support</h2>
            </div>
            <div class="space-y-1 text-xs text-slate-600">
              <p class="font-bold text-slate-800">FISU Vietnam Secretariat</p>
              <p>🌐 Website: <a href="http://fisu.vn/" target="_blank" class="text-indigo-600 hover:underline font-mono">www.fisu.vn</a></p>
              <p>✉️ Email: <a href="mailto:contact@fisu.vn" class="text-indigo-600 hover:underline font-mono">contact@fisu.vn</a></p>
            </div>
          </div>
        </div>

      </div>

      <!-- PHẦN GHI CHÚ PHỤ CUỐI TRANG -->
      <div class="mt-6 text-center text-[11px] text-slate-400 italic">
        * Standard response time for email inquiries is within 24-48 business hours.
      </div>

    </div>
  </main>
</Layout>